#: data/classic/actions.ruleset:303
#, c-format
msgid "Sell %sGoods%s"
msgstr "Sälj %svaror%s"

#: data/classic/actions.ruleset:331 data/sandbox/actions.ruleset:389 data/civ2civ3/actions.ruleset:339 data/alien/actions.ruleset:288 data/multiplayer/actions.ruleset:324 data/granularity/actions.ruleset:220
#, c-format
msgid "%sDisembark from non native%s"
msgstr "%sStig av från icke-inhemsk ruta%s"

#: data/classic/actions.ruleset:335 data/sandbox/actions.ruleset:401 data/civ2civ3/actions.ruleset:343 data/multiplayer/actions.ruleset:328
#, c-format
msgid "Eliminate %sSpy%s"
msgstr "Eliminera %sspion%s"

#: data/classic/actions.ruleset:339 data/multiplayer/actions.ruleset:332
#, c-format
msgid "%sConquer Fortress%s"
msgstr "%sErövra fästning%s"

#: data/classic/actions.ruleset:343 data/multiplayer/actions.ruleset:336
#, c-format
