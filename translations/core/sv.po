#~ "  11 Munkvärld (hexagonal)\n"
#~ "  12 Platt Jord (iso-hex)\n"
#~ "  13 Jord (iso-hex)\n"
#~ "  14 Uranus (iso-hex)\n"
#~ "  15 Munkvärld (iso-hex)\n"
#~ "Klassisk rektangulär:       Isometrisk rektangulär:\n"
#~ "      _________               /\\/\\/\\/\\/\\ \n"
#~ "     |_|_|_|_|_|             /\\/\\/\\/\\/\\/ \n"
#~ "     |_|_|_|_|_|             \\/\\/\\/\\/\\/\\\n"
#~ "     |_|_|_|_|_|             /\\/\\/\\/\\/\\/ \n"
#~ "                             \\/\\/\\/\\/\\/  \n"
