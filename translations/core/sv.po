#: data/nation/animals.ruleset:8
msgid "Before civilization claimed the lands, ancient man had to survive the wilderness with all kinds of dangerous animals."
msgstr "Innan civilisationen tog markerna i besittning måste forntidens människor överleva i vildmarken bland alla slags farliga djur."

#: data/nation/apache.ruleset:5
msgid "Apache"
msgstr "apachiska"

#: data/nation/apache.ruleset:6
