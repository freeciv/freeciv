#~ "     |_|_|_|_|_|             /\\/\\/\\/\\/\\/ \n"
#~ "                             \\/\\/\\/\\/\\/  \n"
#~ "Hex tiles:                 Iso-hex:\n"
#~ "  /\\/\\/\\/\\/\\/\\               _   _   _   _   _       \n"
#~ "  | | | | | | |             / \\_/ \\_/ \\_/ \\_/ \\      \n"
#~ "  \\/\\/\\/\\/\\/\\/\\             \\_/ \\_/ \\_/ \\_/ \\_/  \n"
