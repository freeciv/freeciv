msgstr "Animera markören"

#: client/options.c:3421 client/options.c:3460
msgid "If this option is disabled, the cursor will always be displayed as static."
msgstr "Om detta alternativ är inaktiverat visas pekaren alltid som statisk."

#: client/options.c:3424 client/options.c:3463
msgid "Use color cursors"
msgstr "Använd färgade markörer"

#: client/options.c:3425 client/options.c:3464
