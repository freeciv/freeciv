#~ "0 = Scenariokarta - inget slumpval;\n"
#~ "1 = Helt slumpmässig höjdgenerator;               [4]\n"
#~ "2 = Pseudofraktal höjdgenerator;                  [3]\n"
#~ "3 = Öbaserad generator (rättvisare fast tråkig)   [1]\n"
