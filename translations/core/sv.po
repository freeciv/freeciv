#: data/civ2/units.ruleset:34 data/civ2/units.ruleset:931 data/classic/units.ruleset:41 data/classic/units.ruleset:960 data/sandbox/units.ruleset:49 data/sandbox/units.ruleset:1130 data/civ2civ3/units.ruleset:43 data/civ2civ3/units.ruleset:1074 data/alien/units.ruleset:33 data/multiplayer/units.ruleset:41 data/multiplayer/units.ruleset:1000
