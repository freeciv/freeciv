#: common/reqtext.c:3231
#, c-format
msgid "All adjacent tiles must be at latitude %d or further south."
msgstr "Alla intilliggande rutor måste ligga på latitud %d eller längre söderut."

#: common/reqtext.c:3255
#, c-format
msgid "Some part of the world must be at latitude %d or further south."
msgstr "Någon del av världen måste ligga på latitud %d eller längre söderut."

#: common/reqtext.c:3260
#, c-format
msgid "The entire world must be at latitude %d or further north."
msgstr "Hela världen måste ligga på latitud %d eller längre norrut."

#: common/reqtext.c:3281
#, c-format
msgid "A cardinally adjacent tile must be at latitude %d or further south."
msgstr "En direkt intilliggande ruta måste vara på latitud %d eller längre söderut."

#: common/reqtext.c:3286
#, c-format
msgid "All cardinally adjacent tiles must be at latitude %d or further north."
msgstr "Alla direkt intilliggande rutor måste vara på latitud %d eller längre norrut."

#: common/reqtext.c:3295
#, c-format
msgid "An adjacent tile must be at latitude %d or further south."
msgstr "En intilliggande ruta måste ligga på latitud %d eller längre söderut."

#: common/reqtext.c:3300
#, c-format
msgid "All adjacent tiles must be at latitude %d or further north."
msgstr "Alla intilliggande rutor måste ligga på latitud %d eller längre norrut."

#: common/reqtext.c:3327
msgid "Must be the same tile."
msgstr "Måste vara samma ruta."

#: common/reqtext.c:3329
msgid "Must not be the same tile."
msgstr "Får inte vara samma ruta."

#: common/reqtext.c:3334
msgid "Must be cardinally adjacent."
msgstr "Måste vara direkt intilliggande."

#: common/reqtext.c:3336
msgid "Must not be cardinally adjacent."
msgstr "Får inte vara direkt intilliggande."

#: common/reqtext.c:3342
msgid "Must be adjacent."
msgstr "Måste vara intilliggande."

#: common/reqtext.c:3344
msgid "Must not be adjacent."
msgstr "Får inte vara intilliggande."

#: common/reqtext.c:3351
#, c-format
msgid "The squared distance between the tiles must be at most %d."
msgstr "Det kvadrerade avståndet mellan rutorna får vara högst %d."

#: common/reqtext.c:3356
#, c-format
msgid "The squared distance between the tiles must be at least %d."
msgstr "Det kvadrerade avståndet mellan rutorna måste vara minst %d."

#: common/reqtext.c:3389
msgid "No other cardinally adjacent tile may be part of the same continent or ocean."
msgstr "Ingen annan direkt intilliggande ruta får vara del av samma kontinent eller hav."

#: common/reqtext.c:3394
#, c-format
msgid "No more than %d other cardinally adjacent tile may be part of the same continent or ocean."
msgid_plural "No more than %d other cardinally adjacent tiles may be part of the same continent or ocean."
msgstr[0] "Högst %d annan direkt intilliggande ruta får vara del av samma kontinent eller hav."
msgstr[1] "Högst %d andra direkt intilliggande rutor får vara del av samma kontinent eller hav."

#: common/reqtext.c:3403
#, c-format
msgid "Requires at least %d other cardinally adjacent tile of the same continent or ocean."
msgid_plural "Requires at least %d other cardinally adjacent tiles of the same continent or ocean."
msgstr[0] "Kräver minst %d annan direkt intilliggande ruta som hör till samma kontinent eller hav."
msgstr[1] "Kräver minst %d andra direkt intilliggande rutor som hör till samma kontinent eller hav."

#: common/reqtext.c:3420
msgid "No other adjacent tile may be part of the same continent or ocean."
msgstr "Ingen annan intilliggande ruta får utgöra en del av samma kontinent eller hav."

#: common/reqtext.c:3425
#, c-format
msgid "No more than %d other adjacent tile may be part of the same continent or ocean."
msgid_plural "No more than %d other adjacent tiles may be part of the same continent or ocean."
msgstr[0] "Högst %d annan intilliggande ruta får utgöra en del av samma kontinent eller hav."
msgstr[1] "Högst %d andra intilliggande rutor får utgöra en del av samma kontinent eller hav."

#: common/reqtext.c:3434
#, c-format
msgid "Requires at least %d other adjacent tile of the same continent or ocean."
msgid_plural "Requires at least %d other adjacent tiles of the same continent or ocean."
msgstr[0] "Kräver minst %d annan intilliggande ruta som hör till samma kontinent eller hav."
msgstr[1] "Kräver minst %d andra intilliggande rutor som hör till samma kontinent eller hav."

#: common/reqtext.c:3447
#, c-format
msgid "Requires a continent or ocean size of at most %d."
msgstr "Kräver en kontinent- eller havsstorlek på högst %d."

#: common/reqtext.c:3451
#, c-format
msgid "Requires a continent or ocean size of at least %d."
msgstr "Kräver en kontinent- eller havsstorlek på minst %d."

#: common/reqtext.c:3477
msgid "Must be on the same terrain class."
msgstr "Måste vara på samma terrängklass."

#: common/reqtext.c:3480
msgid "Must be on a different terrain class."
msgstr "Måste tillhöra en annan terrängklass."

#: common/reqtext.c:3487
msgid "Must be cardinally adjacent to the same terrain class."
msgstr "Måste vara direkt intill en ruta av samma terrängklass."

#: common/reqtext.c:3491
msgid "Must not be cardinally adjacent to the same terrain class."
msgstr "Får inte vara direkt intill en ruta av samma terrängklass."

#: common/reqtext.c:3499
msgid "Must be adjacent to the same terrain class."
msgstr "Måste vara intill samma terrängklass."

#: common/reqtext.c:3502
msgid "Must not be adjacent to the same terrain class."
msgstr "Får inte vara intill samma terrängklass."

#: common/reqtext.c:3525
msgid "Must be on the same continent or ocean."
msgstr "Måste vara på samma kontinent eller hav."

#: common/reqtext.c:3528
msgid "Must be on a different continent or ocean."
msgstr "Måste tillhöra en annan kontinent eller ett annat hav."

#: common/reqtext.c:3535
msgid "Must be cardinally adjacent to the same continent or ocean."
msgstr "Måste vara direkt intilliggande till samma kontinent eller hav."

#: common/reqtext.c:3539
msgid "Must not be cardinally adjacent to the same continent or ocean."
msgstr "Får inte vara direkt intilliggande till samma kontinent eller hav."

#: common/reqtext.c:3547
msgid "Must be adjacent to the same continent or ocean."
msgstr "Måste vara intill samma kontinent eller hav."

#: common/reqtext.c:3551
msgid "Must not be adjacent to the same continent or ocean."
msgstr "Får inte vara intill samma kontinent eller hav."

#: common/reqtext.c:3574
msgid "May only be cardinally adjacent to this other continent or ocean."
msgstr "Får endast vara direkt intill denna andra kontinent eller detta andra hav."

#: common/reqtext.c:3578
msgid "Must be cardinally adjacent to more than just this other continent or ocean."
msgstr "Måste vara direkt intill mer än bara denna andra kontinent eller detta andra hav."

#: common/reqtext.c:3586
msgid "May only be adjacent to this other continent or ocean."
msgstr "Får endast vara intill denna andra kontinent eller detta andra hav."

#: common/reqtext.c:3590
msgid "Must be adjacent to more than just this other continent or ocean."
msgstr "Måste vara intill mer än bara denna andra kontinent eller detta andra hav."

#: common/reqtext.c:3614
msgid "Must be on a lake or island surrounded by this continent or ocean."
msgstr "Måste vara del av en sjö eller ö som omges av denna kontinent eller detta hav."

#: common/reqtext.c:3618
msgid "Must not be on a lake or island surrounded by this continent or ocean."
msgstr "Får inte vara del av en sjö eller ö som omges av denna kontinent eller detta hav."

#: common/reqtext.c:3626
msgid "Must be on or cardinally adjacent to a lake or island surrounded by this continent or ocean."
msgstr "Måste vara del av eller direkt intill en sjö eller ö som omges av denna kontinent eller detta hav."

#: common/reqtext.c:3631
msgid "Must not be on nor cardinally adjacent to a lake or island surrounded by this continent or ocean."
msgstr "Får varken vara del av eller direkt intill en sjö eller ö som omges av denna kontinent eller detta hav."

#: common/reqtext.c:3640
msgid "Must be on or adjacent to a lake or island surrounded by this continent or ocean."
msgstr "Måste vara del av eller intill en sjö eller ö som omges av denna kontinent eller detta hav."

#: common/reqtext.c:3644
msgid "Must not be on nor adjacent to a lake or island surrounded by this continent or ocean."
msgstr "Får varken vara del av eller intill en sjö eller ö som omges av denna kontinent eller detta hav."

