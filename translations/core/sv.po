#: data/classic/game.ruleset:441
msgid "Pestilence"
msgstr "Farsot"

#: data/classic/game.ruleset:451 data/sandbox/game.ruleset:466 data/civ2civ3/game.ruleset:468
#| msgid "Industrialization"
msgid "Industrial Accident"
msgstr "industriolycka"

#: data/classic/game.ruleset:460 data/sandbox/game.ruleset:475 data/civ2civ3/game.ruleset:477
msgid "Nuclear Accident"
msgstr "kärnkraftsolycka"

#: data/classic/game.ruleset:469 data/sandbox/game.ruleset:484 data/civ2civ3/game.ruleset:486
msgid "Robbery"
msgstr "Rån"

#: data/classic/script.lua:75 data/sandbox/script.lua:381 data/civ2civ3/script.lua:345
msgid "Highest Peak"
msgstr "högsta topp"

#: data/classic/script.lua:80 data/sandbox/script.lua:228 data/civ2civ3/script.lua:192
msgid "Deep Trench"
msgstr "djupaste havsgrav"

#: data/classic/script.lua:85
msgid "Scorched Spot"
msgstr "Förbränd mark"

#: data/classic/script.lua:90 data/sandbox/script.lua:282 data/civ2civ3/script.lua:246
msgid "Frozen Lake"
msgstr "Frusen sjö"

#: data/classic/styles.ruleset:128 data/sandbox/styles.ruleset:128 data/civ2civ3/styles.ruleset:128 data/multiplayer/styles.ruleset:128
msgid "?citystyle:ElectricAge"
msgstr "elektifierad"

#: data/classic/techs.ruleset:266 data/multiplayer/techs.ruleset:266
msgid "Allows Settlers, Workers and Engineers to build fortresses, and to build oil wells on Desert tiles."
msgstr "Låter nybyggare, arbetare och ingenjörer bygga fästningar och bygga oljekällor på ökenrutor."

#: data/classic/techs.ruleset:416 data/sandbox/techs.ruleset:146 data/civ2civ3/techs.ruleset:145 data/multiplayer/techs.ruleset:425
msgid "Increases units' vision when in fortresses."
msgstr "Ökar truppernas sikt när de befinner sig i fästningar."

#: data/classic/techs.ruleset:473 data/classic/techs.ruleset:772
msgid "Allows establishing one more trade route from each city."
msgstr "Gör det möjligt att inrätta ytterligare en handelsled från varje stad."

#: data/classic/techs.ruleset:638 data/multiplayer/techs.ruleset:646
msgid "Allows Workers and Engineers to build airbases and buoys."
msgstr "Låter arbetare och ingenjörer bygga flygbaser och bojar."

#: data/classic/techs.ruleset:647 data/multiplayer/techs.ruleset:655
msgid "Allows Settlers, Workers and Engineers to upgrade roads to railroads."
msgstr "Tillåter nybyggare, arbetare och ingenjörer att uppgradera vägar till järnvägar."

#: data/classic/techs.ruleset:668 data/multiplayer/techs.ruleset:674
msgid "Allows Settlers, Workers and Engineers to build oil wells on Glacier tiles."
msgstr "Låter nybyggare, arbetare och ingenjörer bygga oljekällor på glaciärrutor."

#: data/classic/techs.ruleset:680 data/multiplayer/techs.ruleset:686
msgid "Allows Settlers, Workers and Engineers to upgrade irrigation systems to farmland."
msgstr "Låter nybyggare, arbetare och ingenjörer uppgradera bevattningssystem till jordbruksmark."

#: data/classic/terrain.ruleset:26 data/multiplayer/terrain.ruleset:26
msgid "Has Oil Well instead of Mine."
msgstr "Har oljekälla i stället för gruva."

#: data/classic/terrain.ruleset:27 data/sandbox/terrain.ruleset:28 data/civ2civ3/terrain.ruleset:28 data/alien/terrain.ruleset:28 data/multiplayer/terrain.ruleset:27
msgid "NoPollution"
msgstr "Inga utsläpp"

#: data/classic/terrain.ruleset:27 data/sandbox/terrain.ruleset:28 data/civ2civ3/terrain.ruleset:28 data/alien/terrain.ruleset:28 data/multiplayer/terrain.ruleset:27
msgid "No Pollution nor Fallout appear here."
msgstr "Varken utsläpp eller nedfall förekommer här."

#: data/classic/terrain.ruleset:219 data/sandbox/terrain.ruleset:227 data/civ2civ3/terrain.ruleset:226 data/alien/terrain.ruleset:220 data/multiplayer/terrain.ruleset:219
msgid "Inaccessible"
msgstr "Otillgänglig"

#: data/classic/terrain.ruleset:256 data/sandbox/terrain.ruleset:264 data/civ2civ3/terrain.ruleset:263 data/multiplayer/terrain.ruleset:256
msgid "No unit can enter this terrain, nor can any city work its tiles."
msgstr "Ingen trupp kan gå in på denna terräng, och ingen stad kan heller bruka dess rutor."

#: data/classic/terrain.ruleset:261 data/sandbox/terrain.ruleset:269 data/civ2civ3/terrain.ruleset:268 data/multiplayer/terrain.ruleset:261
msgid "Lake"
msgstr "sjö"

#: data/classic/terrain.ruleset:306 data/sandbox/terrain.ruleset:314 data/civ2civ3/terrain.ruleset:313 data/multiplayer/terrain.ruleset:304
msgid "Lakes are substantial bodies of fresh water."
msgstr "Sjöar är stora sötvattensamlingar."

#: data/classic/terrain.ruleset:356 data/sandbox/terrain.ruleset:364 data/civ2civ3/terrain.ruleset:363 data/multiplayer/terrain.ruleset:352
msgid "Shallow oceans are mostly found near coastlines, and are often rich sources of food and other resources."
msgstr "Grunda hav finns främst nära kuster och är ofta rika källor till mat och andra resurser."

#: data/classic/terrain.ruleset:362 data/sandbox/terrain.ruleset:370 data/civ2civ3/terrain.ruleset:369 data/multiplayer/terrain.ruleset:358
msgid "Deep Ocean"
msgstr "öppet hav"

#: data/classic/terrain.ruleset:407 data/sandbox/terrain.ruleset:415 data/civ2civ3/terrain.ruleset:414 data/multiplayer/terrain.ruleset:401
msgid "Deep oceans cover much of the world away from coastlines, and only seaworthy units (not including Triremes) can travel on them."
msgstr "Öppet hav täcker stora delar av världen långt från kusterna, och bara sjödugliga trupper (inte triremer) kan färdas där."

#: data/classic/terrain.ruleset:462 data/multiplayer/terrain.ruleset:454
msgid "Oil wells can be built when Refining is known."
msgstr "Oljekällor kan byggas när raffinering är känd."

#: data/classic/terrain.ruleset:517 data/multiplayer/terrain.ruleset:507
msgid "Oil wells can be built when Construction is known."
msgstr "Oljekällor kan byggas när byggnadskonst är känd."

#: data/classic/terrain.ruleset:1104 data/multiplayer/terrain.ruleset:1078
#| msgid "Build Fortress"
msgid "?gui_type:Build Fortress/Buoy"
msgstr "Bygg fästning/boj"

#: data/classic/terrain.ruleset:1107 data/multiplayer/terrain.ruleset:1081
#| msgid "Build Airbase"
msgid "?gui_type:Build Airbase"
msgstr "Bygg flygbas"

#: data/classic/terrain.ruleset:1251 data/multiplayer/terrain.ruleset:1225
msgid "Building an irrigation system on a suitable tile causes it to produce one extra food each turn. This requires a nearby source of water: an ocean, lake, or river tile, or another tile with an irrigation system, must share an edge (not just a corner) with the target tile. However, once irrigated, land remains so even if the water source is removed."
msgstr "Att bygga en bevattningsanläggning på en lämplig ruta gör att den producerar 1 extra mat varje omgång. Detta kräver en närliggande vattenkälla: en havs-, sjö- eller flodruta, eller en annan ruta med en bevattningsanläggning, måste dela en kant (inte bara ett hörn) med målrutan. När marken väl har bevattnats förblir den dock bevattnad även om vattenkällan tas bort."

#: data/classic/terrain.ruleset:1258 data/sandbox/terrain.ruleset:1286 data/civ2civ3/terrain.ruleset:1285 data/multiplayer/terrain.ruleset:1232
msgid "Building irrigation on a tile with a mine or oil well will destroy it."
msgstr "Om bevattning byggs på en ruta med en gruva eller oljekälla förstörs den."

#: data/classic/terrain.ruleset:1260 data/sandbox/terrain.ruleset:1288 data/civ2civ3/terrain.ruleset:1287 data/multiplayer/terrain.ruleset:1234
msgid "City center tiles get their terrain's irrigation bonus automatically, if there is no conflicting mine or oil well on the tile; however, this does not make cities count as a water source for further irrigation. Irrigation can be built on the city tile simply to allow building further irrigation elsewhere, but will not give the tile any further bonus."
msgstr "Stadskärnans rutor får automatiskt landskapets bevattningsbonus om det inte finns någon motstridig gruva eller oljekälla på rutan. Detta gör dock inte att städer räknas som vattenkällor för fortsatt bevattning. Bevattning kan byggas på stadsrutan enbart för att göra det möjligt att bygga ytterligare bevattning på andra håll, men ger inte rutan någon ytterligare bonus."

#: data/classic/terrain.ruleset:1299 data/sandbox/terrain.ruleset:1329 data/civ2civ3/terrain.ruleset:1328 data/multiplayer/terrain.ruleset:1273
msgid "Oil Well"
msgstr "Oljekälla"

#: data/classic/terrain.ruleset:1318 data/multiplayer/terrain.ruleset:1292
msgid "Oil wells behave like mines (giving an extra production point), but require more technology. Oil wells can be built on Desert with knowledge of Construction, and on Glacier with knowledge of Refining."
msgstr "Oljekällor fungerar som gruvor (de ger en extra produktionspoäng), men kräver mer avancerad teknologi. Oljekällor kan byggas på öken när byggnadskonst är känd och på glaciär när raffinering är känd."

#: data/classic/terrain.ruleset:1322 data/multiplayer/terrain.ruleset:1296
msgid "Building an oil well on an irrigated tile will destroy the irrigation."
msgstr "Om en oljekälla byggs på en bevattnad ruta förstörs bevattningen."

#: data/classic/terrain.ruleset:1345
msgid "Pollution appears on land tiles around cities with high production or population, or when a Mfg. Plant suffers an industrial accident. It halves all output from its tile, and contributes to the risk of global warming."
msgstr "Föroreningar uppstår på landrutor runt städer med hög produktion eller stor befolkning, eller när en tillverkningsanläggning råkar ut för en industriolycka. De halverar all avkastning från rutan och bidrar till risken för global uppvärmning."

#: data/classic/terrain.ruleset:1350 data/multiplayer/terrain.ruleset:1324
msgid "The pollution can only be cleared by dispatching Workers, Settlers, or Engineers with the \"clean pollution\" order."
msgstr "Föroreningarna kan bara saneras genom att skicka arbetare, nybyggare eller ingenjörer med ordern ”sanera föroreningar”."

#: data/classic/terrain.ruleset:1369 data/sandbox/terrain.ruleset:1430 data/civ2civ3/terrain.ruleset:1429 data/multiplayer/terrain.ruleset:1344
msgid "When an unused tile becomes polluted, there is the temptation to avoid the effort of cleaning it; but the spread of pollution has far more terrible results than the immediate economic impact -- every polluted tile increases the chance of global warming. Each time global warming advances, the entire world loses coastal land to the sea and to jungles and swamps, and inland tiles are lost to desert. This tends to devastate cities and leads to global impoverishment."
msgstr "När en oanvänd ruta förorenas kan det vara frestande att undvika arbetet med att sanera den, men spridningen av föroreningar får långt värre följder än den omedelbara ekonomiska skadan – varje förorenad ruta ökar risken för global uppvärmning. Varje gång den globala uppvärmningen fortskrider förlorar hela världen kustland till havet samt till djungler och träsk, medan inlandsrutor förvandlas till öken. Detta tenderar att ödelägga städer och leder till global utarmning."

#: data/classic/terrain.ruleset:1447 data/sandbox/terrain.ruleset:1542 data/civ2civ3/terrain.ruleset:1511 data/multiplayer/terrain.ruleset:1420
msgid "Like irrigation, farmland is incompatible with mines and oil wells."
msgstr "Liksom bevattning är åkermark oförenlig med gruvor och oljekällor."

#: data/classic/terrain.ruleset:1452 data/sandbox/terrain.ruleset:1547 data/civ2civ3/terrain.ruleset:1516 data/alien/terrain.ruleset:949 data/multiplayer/terrain.ruleset:1425
msgid "Fallout"
msgstr "Nedfall"

#: data/classic/terrain.ruleset:1470
msgid "Nuclear fallout can appear on land tiles when a Nuclear unit is detonated, or when a city's Nuclear Plant has an accident. It halves all output from its tile."
msgstr "Radioaktivt nedfall kan uppstå på landrutor när en kärnvapentrupp detoneras eller när ett kärnkraftverk i en stad råkar ut för en olycka. Det halverar all avkastning från rutan."

#: data/classic/terrain.ruleset:1474 data/sandbox/terrain.ruleset:1569 data/civ2civ3/terrain.ruleset:1538 data/multiplayer/terrain.ruleset:1446
msgid "Every tile with nuclear fallout also increases the risk of global nuclear winter. If nuclear winter occurs, land across the globe changes into desert, tundra, and ice, and lakes and oceans freeze."
msgstr "Varje ruta med radioaktivt nedfall ökar också risken för global atomvinter. Om atomvinter inträffar förvandlas land över hela världen till öken, tundra och is, och sjöar och hav fryser."

#: data/classic/terrain.ruleset:1478 data/multiplayer/terrain.ruleset:1450
msgid "Settlers, Workers, and Engineers can clean up nuclear fallout."
msgstr "Nybyggare, arbetare och ingenjörer kan sanera radioaktivt nedfall."

#: data/classic/terrain.ruleset:1508 data/multiplayer/terrain.ruleset:1480
msgid "Fortresses improve defense for land units outside cities. Among other effects, a land unit remaining in a fortress for a whole turn without moving recovers a quarter of its hit points. With Invention, fortresses gain watchtowers from which land units can see further afield."
msgstr "Fästningar förbättrar försvaret för marktrupper utanför städer. Bland annat återfår en marktrupp som stannar i en fästning en hel omgång utan att förflytta sig en fjärdedel av sina träffpoäng. Med uppfinning får fästningar vakttorn varifrån marktrupper kan se längre."

#: data/classic/terrain.ruleset:1551 data/sandbox/terrain.ruleset:1788 data/civ2civ3/terrain.ruleset:1713 data/multiplayer/terrain.ruleset:1523
msgid "Buoy"
msgstr "Boj"

#: data/classic/terrain.ruleset:1573 data/multiplayer/terrain.ruleset:1545
msgid "Buoys may be built in the ocean (by units on a sea-going vessel) to allow their owner to see the surrounding tiles."
msgstr "Bojar kan byggas i havet (av trupper ombord på ett sjögående fartyg) så att deras ägare kan se de omgivande rutorna."

#: data/classic/terrain.ruleset:1579 data/sandbox/terrain.ruleset:1821 data/civ2civ3/terrain.ruleset:1742 data/multiplayer/terrain.ruleset:1551
msgid "Ruins"
msgstr "Ruiner"

#: data/classic/terrain.ruleset:1599 data/sandbox/terrain.ruleset:1841 data/civ2civ3/terrain.ruleset:1762 data/multiplayer/terrain.ruleset:1571
msgid "Ruins mark the former site of a city that was destroyed or abandoned. They have no effect on gameplay."
msgstr "Ruiner markerar den tidigare platsen för en stad som förstörts eller övergivits. De påverkar inte spelet."

#: data/classic/terrain.ruleset:1631 data/multiplayer/terrain.ruleset:1603
msgid "Building roads on river tiles requires knowledge of Bridge Building. City center tiles automatically get roads (unless they are on a river tile and you do not yet know Bridge Building)."
msgstr "För att bygga vägar på flodrutor krävs kunskap om brobyggnad. Stadskärnans rutor får automatiskt vägar (såvida de inte ligger på en flodruta och du ännu inte känner till brobyggnad)."

#: data/classic/units.ruleset:35 data/sandbox/units.ruleset:38 data/civ2civ3/units.ruleset:34 data/multiplayer/units.ruleset:35
msgid "Unbribable"
msgstr "Kan inte mutas"

#: data/classic/units.ruleset:45 data/multiplayer/units.ruleset:45
#| msgid "Best attacking units"
msgid "Bad at attacking Fighters"
msgstr "Dålig på att angripa jaktflygplan"

#: data/classic/units.ruleset:56 data/sandbox/units.ruleset:69 data/civ2civ3/units.ruleset:59 data/multiplayer/units.ruleset:56
msgid "AttFromNonNative"
msgstr "AttFromNonNative"

#: data/classic/units.ruleset:66 data/sandbox/units.ruleset:82 data/sandbox/units.ruleset:2381 data/civ2civ3/units.ruleset:72 data/civ2civ3/units.ruleset:2273 data/multiplayer/units.ruleset:66
msgid "hardened"
msgstr "härdad"

#: data/classic/units.ruleset:66 data/sandbox/units.ruleset:82 data/sandbox/units.ruleset:2381 data/civ2civ3/units.ruleset:72 data/civ2civ3/units.ruleset:2273 data/multiplayer/units.ruleset:66
msgid "elite"
msgstr "elit"

#. TRANS: Unit class: used adjectivally
#: data/classic/units.ruleset:171 data/sandbox/units.ruleset:215 data/civ2civ3/units.ruleset:203 data/multiplayer/units.ruleset:171
msgid "?unitclass:Trireme"
msgstr "trirem"

#: data/classic/units.ruleset:479 data/sandbox/units.ruleset:527 data/civ2civ3/units.ruleset:514 data/multiplayer/units.ruleset:479
msgid "Settlers are one of the key units in the game, as they are your main means of founding new cities."
msgstr "Nybyggare är en av spelets viktigaste trupptyper, eftersom de är ditt främsta sätt att grunda nya städer."

#: data/classic/units.ruleset:482 data/multiplayer/units.ruleset:482
msgid "Settlers can also perform most of the same terrain alterations as Workers (but cannot build Airbases or Buoys)."
msgstr "Nybyggare kan också utföra de flesta av samma landskapsförändringar som arbetare (men kan inte bygga flygbaser eller bojar)."

#: data/classic/units.ruleset:492 data/sandbox/units.ruleset:585 data/civ2civ3/units.ruleset:572 data/multiplayer/units.ruleset:493 data/granularity/units.ruleset:813
msgid "?unit:Workers"
msgstr "Arbetare"

#: data/classic/units.ruleset:528 data/sandbox/units.ruleset:619 data/civ2civ3/units.ruleset:605 data/multiplayer/units.ruleset:529
msgid "Workers have the ability to improve terrain tiles. See the help on Terrain and Terrain Alterations for the effects of their actions."
msgstr "Arbetare kan förbättra landskapsrutor. Se hjälpen om landskap och landskapsförändringar för effekterna av deras handlingar."

#: data/classic/units.ruleset:531 data/multiplayer/units.ruleset:532
msgid "Workers can build airbases and buoys, which Settlers cannot. Workers must be on board a ship to build buoys."
msgstr "Arbetare kan bygga flygbaser och bojar, vilket nybyggare inte kan. Arbetare måste vara ombord på ett fartyg för att bygga bojar."

#: data/classic/units.ruleset:573 data/multiplayer/units.ruleset:574
msgid "Engineers are similar to Workers, but they work twice as fast and move twice as fast. Engineers may also perform major terrain transformations which are beyond the capabilities of Workers and Settlers, such as converting Tundra into Desert, or even Ocean into Swamp in some circumstances (when on board an ocean-going vessel, on a tile surrounded by sufficient existing land). See the Terrain Alterations section for more details."
msgstr "Ingenjörer liknar arbetare, men de arbetar dubbelt så snabbt och förflyttar sig dubbelt så snabbt. Ingenjörer kan också utföra större terrängomvandlingar som arbetare och nybyggare inte klarar, till exempel omvandla tundra till öken, eller i vissa fall till och med hav till träsk när de befinner sig ombord på ett havsgående fartyg på en ruta som omges av tillräckligt mycket befintligt land. Se avsnittet Terrängändringar för mer information."

#: data/classic/units.ruleset:581 data/multiplayer/units.ruleset:582
msgid "TIP 1:  Upgrade Workers to Engineers when possible, as Engineers require the same resources as ordinary Workers."
msgstr "TIPS 1:  Uppgradera arbetare till ingenjörer när det är möjligt, eftersom ingenjörer kräver samma resurser som vanliga arbetare."

#: data/classic/units.ruleset:584 data/multiplayer/units.ruleset:585
msgid "TIP 2:  If you manage to build Leonardo's Workshop, research Explosives before the Workshop becomes obsolete.  This way, your Workers units will be upgraded for free."
msgstr "TIPS 2:  Om du lyckas bygga Leonardos verkstad bör du forska fram sprängämnen innan verkstaden blir föråldrad. På så sätt uppgraderas dina arbetare gratis."

#: data/classic/units.ruleset:1638 data/multiplayer/units.ruleset:1749
msgid "The Trireme is your first boat unit. It can act as a transport ship and has rudimentary offensive capabilities, but may not enter deep ocean tiles."
msgstr "Triremen är din första marina enhet. Den kan fungera som transportskepp och har grundläggande anfallsförmåga, men får inte färdas på rutor med öppet hav."

#: data/classic/units.ruleset:1676 data/multiplayer/units.ruleset:1787
msgid "The Caravel replaces the Trireme and can enter any ocean tile."
msgstr "Karavellen ersätter triremen och kan färdas på alla havsrutor."

#: data/classic/units.ruleset:2139 data/sandbox/units.ruleset:2484 data/sandbox/units.ruleset:2546 data/civ2civ3/units.ruleset:2375 data/multiplayer/units.ruleset:2250
msgid "On impact, the blast will destroy any unit in an area 3 tiles wide (3x3 squares for rectangular grids), including friendly units. Any city within the blast area loses half its population, and land tiles within the blast area are subject to nuclear fallout."
msgstr "Vid nedslaget förstör explosionen alla trupper inom ett område som är 3 rutor brett (3 × 3 rutor på rektangulära rutnät), även vänliga trupper. Alla städer inom explosionsområdet förlorar hälften av sin befolkning, och landrutor inom området kan drabbas av radioaktivt nedfall."

#: data/classic/units.ruleset:2144 data/sandbox/units.ruleset:2489 data/sandbox/units.ruleset:2551 data/civ2civ3/units.ruleset:2380 data/multiplayer/units.ruleset:2255
msgid "Nuclear fallout reduces tile output and increases the risk of global nuclear winter; see the help on Fallout."
msgstr "Radioaktivt nedfall minskar rutans avkastning och ökar risken för global atomvinter. Se hjälpen om radioaktivt nedfall."

#: data/classic/units.ruleset:2151 data/multiplayer/units.ruleset:2262
msgid "TIP 2:  You may be involved in a situation where you've invaded an enemy country en masse, but the enemy cities are too strong. Before using a Nuclear unit, assemble a gang of Settlers, Workers, and/or Engineers next to the city and have them ready to fix the fallout on the same turn it occurs!  This minimizes the chance of nuclear winter.  Eco-friendly nukes!"
msgstr "TIPS 2:  Du kan hamna i en situation där du har invaderat ett fiendeland med stora styrkor men fiendens städer är för starka. Innan du använder en kärnvapentrupp kan du samla en grupp nybyggare, arbetare och/eller ingenjörer intill staden och låta dem vara redo att sanera nedfallet under samma omgång som det uppstår! Det minimerar risken för atomvinter. Miljövänliga kärnvapen!"

#. TRANS: diplomatic rank.
#: data/classic/units.ruleset:2192 data/sandbox/units.ruleset:2600 data/civ2civ3/units.ruleset:2426 data/multiplayer/units.ruleset:2303
msgid "?diplomatic_rank:attaché"
msgstr "attaché"

#. TRANS: diplomatic rank
#: data/classic/units.ruleset:2194 data/sandbox/units.ruleset:2602 data/civ2civ3/units.ruleset:2428 data/multiplayer/units.ruleset:2305
msgid "?diplomatic_rank:secretary"
msgstr "sekreterare"

#. TRANS: diplomatic rank
#: data/classic/units.ruleset:2196 data/sandbox/units.ruleset:2604 data/civ2civ3/units.ruleset:2430 data/multiplayer/units.ruleset:2307
msgid "?diplomatic_rank:envoy"
msgstr "sändebud"

#. TRANS: diplomatic rank
#: data/classic/units.ruleset:2198 data/sandbox/units.ruleset:2606 data/civ2civ3/units.ruleset:2432 data/multiplayer/units.ruleset:2309
msgid "?diplomatic_rank:ambassador"
msgstr "ambassadör"

#: data/classic/units.ruleset:2221 data/sandbox/units.ruleset:2630 data/civ2civ3/units.ruleset:2456 data/multiplayer/units.ruleset:2332
msgid "Diplomats can also perform a number of actions in another player's city, although each Diplomat may attempt only one action. Most of these actions have a chance of failure. Also, any enemy Diplomats or Spies in the city will oppose hostile actions, as will the enemy Leader in games with leaders; in this case, either your unit or the defending unit will die (if you go up against the Leader you will always die). If the defending unit dies, you lose one movement point and may try again."
msgstr "Diplomater kan också utföra ett antal handlingar i en annan spelares stad, men varje diplomat får bara försöka utföra en handling. De flesta av dessa handlingar kan misslyckas. Fientliga diplomater eller spioner i staden motverkar också fientliga handlingar, liksom fiendens ledare i spel med ledare. I så fall dör antingen din trupp eller den försvarande truppen (om du möter ledaren dör du alltid). Om den försvarande truppen dör förlorar du en dragpoäng och kan försöka igen."

#: data/classic/units.ruleset:2266 data/multiplayer/units.ruleset:2377
msgid "Diplomats built under a Communist government will start at the first veteran level (secretary)."
msgstr "Diplomater som byggs under kommunistiskt statsskick börjar på den första erfarenhetsnivån (sekreterare)."

#. TRANS: Spy veteran level
#: data/classic/units.ruleset:2304 data/sandbox/units.ruleset:2729 data/civ2civ3/units.ruleset:2555 data/multiplayer/units.ruleset:2415
msgid "?spy_level:informant"
msgstr "informatör"

#. TRANS: Spy veteran level
#: data/classic/units.ruleset:2306 data/sandbox/units.ruleset:2731 data/civ2civ3/units.ruleset:2557 data/multiplayer/units.ruleset:2417
msgid "?spy_level:handler"
msgstr "agentförare"

#. TRANS: Spy veteran level
#: data/classic/units.ruleset:2308 data/sandbox/units.ruleset:2733 data/civ2civ3/units.ruleset:2559 data/multiplayer/units.ruleset:2419
msgid "?spy_level:agent"
msgstr "agent"

#. TRANS: Spy veteran level
#: data/classic/units.ruleset:2310 data/sandbox/units.ruleset:2735 data/civ2civ3/units.ruleset:2561 data/multiplayer/units.ruleset:2421
msgid "?spy_level:spymaster"
msgstr "spionmästare"

#: data/classic/units.ruleset:2340 data/multiplayer/units.ruleset:2451
msgid "Spies built under a Communist government will start at the first veteran level (handler)."
msgstr "Spioner som byggs under kommunistiskt statsskick börjar på den första erfarenhetsnivån (agentförare)."

#: data/classic/units.ruleset:2379
msgid "Caravans can establish trade routes with your own cities or those of other nations (even enemies) by traveling to them. A route's ongoing revenue is doubled if the two cities involved are on different continents, and doubled again if the cities are from different civilizations. This last condition means the net benefit to your civilization of a trade route is the same regardless of whether you own both cities or only one of them; if you only own one city, trade in each city is doubled, but you only get the benefit from one end of the route."
msgstr "Karavaner kan upprätta handelsleder med dina egna eller andra nationers städer (även fienders) genom att färdas till dem. En handelsleds löpande intäkter fördubblas om de två städerna ligger på olika kontinenter och fördubblas igen om städerna tillhör olika civilisationer. Det sistnämnda innebär att nettovinsten för din civilisation är densamma oavsett om du äger båda städerna eller bara en av dem. Om du bara äger en stad fördubblas handeln i båda städerna, men du får bara nytta av den ena änden av leden."

#: data/classic/units.ruleset:2388
msgid "Initially cities can support a maximum of two trade routes. Knowledge of the technologies Magnetism and The Corporation each increase this limit by one; knowing both allows cities to support four trade routes each."
msgstr "Till en början kan städer ha högst två handelsleder. Kunskap om teknologierna magnetism och bolaget höjer vardera gränsen med en. Om du känner till båda kan varje stad ha fyra handelsleder."

#: data/classic/units.ruleset:2432
msgid "The Freight unit replaces the Caravan, and moves at twice the speed."
msgstr "Godsvagnen ersätter karavanen och rör sig dubbelt så fort."

#: data/classic/units.ruleset:2473 data/sandbox/units.ruleset:2914 data/civ2civ3/units.ruleset:2734 data/multiplayer/units.ruleset:2572
msgid "?unit:Leader"
msgstr "ledare"

#: data/classic/units.ruleset:2508 data/sandbox/units.ruleset:2949 data/civ2civ3/units.ruleset:2769 data/multiplayer/units.ruleset:2607
msgid "This is you. If you lose this unit, you lose the game. So don't."
msgstr "Detta är du. Besegras denna trupp förlorar du spelet. Försök undvika det."

#: data/classic/units.ruleset:2510 data/sandbox/units.ruleset:2951 data/civ2civ3/units.ruleset:2771 data/multiplayer/units.ruleset:2609
#| msgid "* Only barbarians may build this.\n"
msgid "Won't unleash barbarians from huts."
msgstr "Släpper inte lös barbarer från byar."

#: data/classic/units.ruleset:2561 data/sandbox/units.ruleset:3002 data/civ2civ3/units.ruleset:2821 data/multiplayer/units.ruleset:2660
msgid "AWACS"
msgstr "AWACS"

#: data/classic/units.ruleset:2591 data/sandbox/units.ruleset:3032 data/civ2civ3/units.ruleset:2851 data/multiplayer/units.ruleset:2690
msgid "The AWACS (Airborne Warning and Control System) is an airplane with an advanced radar that can determine the location of enemy units over a wide area."
msgstr "AWACS (Airborne Warning and Control System, luftburet varnings- och kontrollsystem) är ett radarutrustat spaningsflygplan som kan fastställa fiendetruppers positioner över ett stort område."

