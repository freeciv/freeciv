#: data/civ2/terrain.ruleset:1638 data/classic/terrain.ruleset:1941 data/sandbox/terrain.ruleset:2267 data/civ2civ3/terrain.ruleset:2157 data/multiplayer/terrain.ruleset:1913
msgid "Whales"
msgstr "valar"

#: data/civ2/terrain.ruleset:1652 data/classic/terrain.ruleset:1955 data/sandbox/terrain.ruleset:2281 data/civ2civ3/terrain.ruleset:2171 data/multiplayer/terrain.ruleset:1927
