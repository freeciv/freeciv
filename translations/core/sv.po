msgid "?terrain:Requires %s on a tile within the city radius."
msgstr "Kräver %s på en ruta inom stadens radie."

#: common/reqtext.c:1058
#, c-format
msgid "?terrain:Prevented by %s on any tile within the city radius."
msgstr "Förhindras av %s på någon ruta inom stadens radie."

#: common/reqtext.c:1067
#, c-format
msgid "?terrain:Requires %s on a tile within the city radius, or the city radius of a trade partner."
msgstr "Kräver %s på en ruta inom stadens radie eller inom en handelspartners stadsradie."

#: common/reqtext.c:1072
#, c-format
msgid "?terrain:Prevented by %s on any tile within the city radius or the city radius of a trade partner."
msgstr "Förhindras av %s på någon ruta inom stadens radie eller inom en handelspartners stadsradie."

#. TRANS: "... playing as the Swedes."
#: common/reqtext.c:1096
#, c-format
msgid "Requires that you are playing as the %s."
msgstr "Kräver att du spelar som %s."

#. TRANS: "... playing as the Turks."
#: common/reqtext.c:1101
#, c-format
msgid "Requires that you are not playing as the %s."
msgstr "Kräver att du inte spelar som %s."

#. TRANS: "... same team as the Indonesians."
#: common/reqtext.c:1110
#, c-format
msgid "Requires that you are on the same team as the %s."
msgstr "Kräver att du är i samma lag som %s."

#. TRANS: "... same team as the Greeks."
#: common/reqtext.c:1116
#, c-format
msgid "Requires that you are not on the same team as the %s."
msgstr "Kräver att du inte är i samma lag som %s."

#. TRANS: "... allied with the Koreans."
#: common/reqtext.c:1126
#, c-format
msgid "Requires that you are allied with the %s."
msgstr "Kräver att du är allierad med %s."

#. TRANS: "... allied with the Danes."
#: common/reqtext.c:1131
#, c-format
msgid "Requires that you are not allied with the %s."
msgstr "Kräver att du inte är allierad med %s."

#. TRANS: "Requires the Apaches to have ..."
#: common/reqtext.c:1141
#, c-format
msgid "Requires the %s to have been in the game."
msgstr "Kräver att %s har varit med i spelet."

#. TRANS: "Requires the Celts never to have ..."
#: common/reqtext.c:1146
#, c-format
msgid "Requires the %s never to have been in the game."
msgstr "Kräver att %s aldrig har varit med i spelet."

#. TRANS: "Requires the Belgians in the game."
#: common/reqtext.c:1154
#, c-format
msgid "Requires the %s in the game."
msgstr "Kräver att %s är med i spelet."

#. TRANS: "Requires that the Russians are not ...
#: common/reqtext.c:1159
#, c-format
msgid "Requires that the %s are not in the game."
msgstr "Kräver att %s inte är med i spelet."

#. TRANS: nation group: "... playing African nation."
#: common/reqtext.c:1184
#, c-format
msgid "Requires that you are playing %s nation."
msgstr "Kräver att du spelar folkslaget %s."

#. TRANS: nation group: "... playing Imaginary nation."
#: common/reqtext.c:1189
#, c-format
msgid "Prevented if you are playing %s nation."
msgstr "Förhindras om du spelar folkslaget %s."

#. TRANS: nation group: "Requires Medieval nation ..."
#: common/reqtext.c:1198
#, c-format
msgid "Requires %s nation on your team."
msgstr "Kräver folkslaget %s i ditt lag."

#. TRANS: nation group: "Prevented by Medieval nation ..."
#: common/reqtext.c:1203
#, c-format
msgid "Prevented by %s nation on your team."
msgstr "Förhindras av att folkslaget %s finns i ditt lag."

#. TRANS: nation group: "Requires Modern nation ..."
#: common/reqtext.c:1212
#, c-format
msgid "Requires %s nation in alliance with you."
msgstr "Kräver att folkslaget %s är allierat med dig."

#. TRANS: nation group: "Prevented by Modern nation ..."
#: common/reqtext.c:1217
#, c-format
msgid "Prevented if %s nation is in alliance with you."
msgstr "Förhindras om folkslaget %s är allierat med dig."

#. TRANS: nation group: "Requires Asian nation ..."
#: common/reqtext.c:1226
#, c-format
msgid "Requires %s nation in the game."
msgstr "Kräver att folkslaget %s är med i spelet."

#. TRANS: nation group: "Prevented by Asian nation ..."
#: common/reqtext.c:1231
#, c-format
msgid "Prevented by %s nation in the game."
msgstr "Förhindras av att folkslaget %s finns i spelet."

#. TRANS: "Requires that you are playing Asian style
#. * nation."
#: common/reqtext.c:1257
#, c-format
msgid "Requires that you are playing %s style nation."
msgstr "Kräver att du spelar ett folkslag i stilen %s."

#. TRANS: "Requires that you are not playing Classical
#. * style nation."
#: common/reqtext.c:1263
#, c-format
msgid "Requires that you are not playing %s style nation."
msgstr "Kräver att du inte spelar ett folkslag i stilen %s."

#. TRANS: "Requires at least one Barbarian citizen ..."
#: common/reqtext.c:1275
#, c-format
msgid "Requires at least one %s citizen in the city or a trade partner."
msgstr "Kräver minst en %s-medborgare i staden eller hos en handelspartner."

#. TRANS: "... no Pirate citizens ..."
#: common/reqtext.c:1281
#, c-format
msgid "Requires that there are no %s citizens in the city or any trade partners."
msgstr "Kräver att det inte finns några %s-medborgare i staden eller hos någon handelspartner."

#. TRANS: "Requires at least one Barbarian citizen ..."
#: common/reqtext.c:1291
#, c-format
msgid "Requires at least one %s citizen in the city."
msgstr "Kräver minst en %s-medborgare i staden."

#. TRANS: "... no Pirate citizens ..."
#: common/reqtext.c:1296
#, c-format
msgid "Requires that there are no %s citizens in the city."
msgstr "Kräver att det inte finns några %s-medborgare i staden."

#: common/reqtext.c:1322
#, c-format
msgid "Requires city to be founded by %s."
msgstr "Kräver att staden grundades av %s."

#: common/reqtext.c:1326
#, c-format
msgid "Requires that city was not originally owned by %s."
msgstr "Kräver att staden inte ursprungligen ägdes av %s."

#. TRANS: in this and following strings, '%s' can be one
#. * of a wide range of relationships; e.g., 'Peace',
#. * 'Never met', 'Foreign', 'Hosts embassy',
#. * 'Provided Casus Belli'
#: common/reqtext.c:1356
#, c-format
msgid "Requires that you have the relationship '%s' with at least one other living player."
msgstr "Kräver att du har relationen ”%s” med minst en annan levande spelare."

#: common/reqtext.c:1361
#, c-format
msgid "Requires that you do not have the relationship '%s' with any living player."
msgstr "Kräver att du inte har relationen ”%s” med någon levande spelare."

#: common/reqtext.c:1370
#, c-format
msgid "Requires that somebody on your team has the relationship '%s' with at least one other living player."
msgstr "Kräver att någon i ditt lag har relationen ”%s” med minst en annan levande spelare."

#: common/reqtext.c:1376
#, c-format
msgid "Requires that nobody on your team has the relationship '%s' with any living player."
msgstr "Kräver att ingen i ditt lag har relationen ”%s” med någon levande spelare."

#: common/reqtext.c:1385
#, c-format
msgid "Requires that somebody in your alliance has the relationship '%s' with at least one other living player."
msgstr "Kräver att någon i ditt förbund har relationen ”%s” med minst en annan levande spelare."

#: common/reqtext.c:1391
#, c-format
msgid "Requires that nobody in your alliance has the relationship '%s' with any living player."
msgstr "Kräver att ingen i ditt förbund har relationen ”%s” med någon levande spelare."

#: common/reqtext.c:1400
#, c-format
msgid "Requires the relationship '%s' between two living players."
msgstr "Kräver relationen ”%s” mellan två levande spelare."

#: common/reqtext.c:1405
#, c-format
msgid "Requires that no two living players have the relationship '%s'."
msgstr "Kräver att inga två levande spelare har relationen ”%s”."

#: common/reqtext.c:1414
#, c-format
msgid "Requires that you have the relationship '%s' with the other player."
msgstr "Kräver att du har relationen ”%s” med den andra spelaren."

#: common/reqtext.c:1419
#, c-format
msgid "Requires that you do not have the relationship '%s' with the other player."
msgstr "Kräver att du inte har relationen ”%s” med den andra spelaren."

#. TRANS: in this and following strings, '%s' can be one
#. * of a wide range of relationships; e.g., 'Peace',
#. * 'Never met', 'Foreign', 'Hosts embassy',
#. * 'Provided Casus Belli'
#: common/reqtext.c:1446
#, c-format
msgid "Requires that the tile owner has the relationship '%s' with at least one other living player."
msgstr "Kräver att rutans ägare har relationen ”%s” med minst en annan levande spelare."

#: common/reqtext.c:1451
#, c-format
msgid "Requires that the tile owner does not have the relationship '%s' with any living player."
msgstr "Kräver att rutans ägare inte har relationen ”%s” med någon levande spelare."

#: common/reqtext.c:1460
#, c-format
msgid "Requires that somebody on the tile owner's team has the relationship '%s' with at least one other living player."
msgstr "Kräver att någon i rutägarens lag har relationen ”%s” med minst en annan levande spelare."

#: common/reqtext.c:1466
#, c-format
msgid "Requires that nobody on the tile owner's team has the relationship '%s' with any living player."
msgstr "Kräver att ingen i rutägarens lag har relationen ”%s” med någon levande spelare."

#: common/reqtext.c:1475
#, c-format
msgid "Requires that somebody in the tile owner's alliance has the relationship '%s' with at least one other living player."
msgstr "Kräver att någon i rutägarens förbund har relationen ”%s” med minst en annan levande spelare."

#: common/reqtext.c:1481
#, c-format
msgid "Requires that nobody in the tile owner's alliance has the relationship '%s' with any living player."
msgstr "Kräver att ingen i rutägarens förbund har relationen ”%s” med någon levande spelare."

#: common/reqtext.c:1490
#, c-format
msgid "Requires that you have the relationship '%s' with the tile owner."
msgstr "Kräver att du har relationen ”%s” med rutans ägare."

#: common/reqtext.c:1495
#, c-format
msgid "Requires that you do not have the relationship '%s' with the tile owner."
msgstr "Kräver att du inte har relationen ”%s” med rutans ägare."

#: common/reqtext.c:1519
#, c-format
msgid "Requires that the tile owner has the relationship '%s' with the other player."
msgstr "Kräver att rutans ägare har relationen ”%s” med den andra spelaren."

#: common/reqtext.c:1524
#, c-format
msgid "Requires that the tile owner does not have the relationship '%s' with the other player."
msgstr "Kräver att rutans ägare inte har relationen ”%s” med den andra spelaren."

#. TRANS: in this and following strings, '%s' can be one
#. * of a wide range of relationships; e.g., 'Peace',
#. * 'Never met', 'Foreign', 'Hosts embassy',
#. * 'Provided Casus Belli'
#: common/reqtext.c:1555
#, c-format
msgid "Requires that the tile has at least one unit whose owner has the relationship '%s' with at least one other living player."
msgstr "Kräver att rutan har minst en trupp vars ägare har relationen ”%s” med minst en annan levande spelare."

#: common/reqtext.c:1561
#, c-format
msgid "Requires that no unit at the tile is owned by a player who has the relationship '%s' with any living player."
msgstr "Kräver att ingen trupp på rutan ägs av en spelare som har relationen ”%s” med någon levande spelare."

#: common/reqtext.c:1570
#, c-format
msgid "Requires that the tile has at least one unit whose owner is on a team where a member has the relationship '%s' with at least one other living player."
msgstr "Kräver att rutan har minst en trupp vars ägare är i ett lag där en medlem har relationen ”%s” med minst en annan levande spelare."

#: common/reqtext.c:1577
#, c-format
msgid "Requires that no unit at the tile is owned by a player who is on a team where a member has the relationship '%s' with at least one other living player."
msgstr "Kräver att ingen trupp på rutan ägs av en spelare som är i ett lag där en medlem har relationen ”%s” med minst en annan levande spelare."

#: common/reqtext.c:1588
#, c-format
msgid "Requires that the tile has at least one unit whose owner is allied to someone that has the relationship '%s' with at least one other living player."
msgstr "Kräver att rutan har minst en trupp vars ägare är allierad med någon som har relationen ”%s” med minst en annan levande spelare."

#: common/reqtext.c:1595
#, c-format
msgid "Requires that no unit at the tile is owned by a player allied to someone that has the relationship '%s' with any living player."
msgstr "Kräver att ingen trupp på rutan ägs av en spelare som är allierad med någon som har relationen ”%s” med någon levande spelare."

#: common/reqtext.c:1605
#, c-format
msgid "Requires that you have the relationship '%s' with the owner of at least one unit at the tile."
msgstr "Kräver att du har relationen ”%s” med ägaren till minst en trupp på rutan."

#: common/reqtext.c:1610
#, c-format
msgid "Requires that you do not have the relationship '%s' with the owner of any unit at the tile."
msgstr "Kräver att du inte har relationen ”%s” med ägaren till någon trupp på rutan."

#: common/reqtext.c:1634
#, c-format
msgid "Requires that the tile has at least one unit whose owner has the relationship '%s' with the other player."
msgstr "Kräver att rutan har minst en trupp vars ägare har relationen ”%s” med den andra spelaren."

#: common/reqtext.c:1639
#, c-format
msgid "Requires that no unit at the tile is owned by a player who has the relationship '%s' with the other player."
msgstr "Kräver att ingen trupp på rutan ägs av en spelare som har relationen ”%s” med den andra spelaren."

#. TRANS: %s is a single kind of unit (e.g., "Settlers").
#: common/reqtext.c:1666
#, c-format
msgid "?unit:Requires %s."
msgstr "Kräver %s."

#. TRANS: %s is a single kind of unit (e.g., "Settlers").
#: common/reqtext.c:1670
#, c-format
msgid "?unit:Does not apply to %s."
msgstr "Gäller inte %s."

#. TRANS: %s is a list of unit types separated by "or".
#: common/reqtext.c:1703
#, c-format
msgid "?ulist:Requires %s."
msgstr "Kräver %s."

#. TRANS: %s is a list of unit types separated by "or".
#: common/reqtext.c:1707
#, c-format
msgid "?ulist:Does not apply to %s."
msgstr "Gäller inte %s."

#. TRANS: %s is a single unit class (e.g., "Air").
#: common/reqtext.c:1737
#, c-format
msgid "?uclass:Requires %s units."
msgstr "Kräver %s-trupper."

#. TRANS: %s is a single unit class (e.g., "Air").
#: common/reqtext.c:1741
#, c-format
msgid "?uclass:Does not apply to %s units."
msgstr "Gäller inte ”%s”-trupper."

#. TRANS: %s is a list of unit classes separated by "or".
#: common/reqtext.c:1780
#, c-format
msgid "?uclasslist:Requires %s units."
msgstr "Kräver %s-trupper."

#. TRANS: %s is a list of unit classes separated by "or".
#: common/reqtext.c:1784
#, c-format
msgid "?uclasslist:Does not apply to %s units."
msgstr "Gäller inte %s-trupper."

#: common/reqtext.c:1820
msgid "Requires that the unit is transported."
msgstr "Kräver att truppen transporteras."

#: common/reqtext.c:1823
msgid "Requires that the unit isn't transported."
msgstr "Kräver att truppen inte transporteras."

#: common/reqtext.c:1830
msgid "Requires that the unit is on livable tile."
msgstr "Kräver att truppen är på en beboelig ruta."

#: common/reqtext.c:1833
msgid "Requires that the unit isn't on livable tile."
msgstr "Kräver att truppen inte är på en beboelig ruta."

#: common/reqtext.c:1840
msgid "Requires that the unit does transport one or more cargo units."
msgstr "Kräver att truppen transporterar en eller flera lastenheter."

#: common/reqtext.c:1844
msgid "Requires that the unit doesn't transport any cargo units."
msgstr "Kräver att truppen inte transporterar några lastenheter."

#: common/reqtext.c:1852
msgid "Requires that the unit has a home city."
msgstr "Kräver att truppen har en hemstad."

#: common/reqtext.c:1855
msgid "Requires that the unit is homeless."
msgstr "Kräver att truppen saknar hemstad."

#: common/reqtext.c:1862
msgid "Requires that the unit is on native tile."
msgstr "Kräver att truppen är på en inhemsk ruta."

#: common/reqtext.c:1865
msgid "Requires that the unit isn't on native tile."
msgstr "Kräver att truppen inte är på en inhemsk ruta."

#: common/reqtext.c:1872
msgid "Requires that the unit is in a native extra."
msgstr "Kräver att truppen är i en inhemsk extraföreteelse."

#: common/reqtext.c:1875
msgid "Requires that the unit isn't in a native extra."
msgstr "Kräver att truppen inte är i en inhemsk extraföreteelse."

#: common/reqtext.c:1882
msgid "Requires that the unit has moved this turn."
msgstr "Kräver att truppen har flyttat denna omgång."

#: common/reqtext.c:1885
msgid "Requires that the unit hasn't moved this turn."
msgstr "Kräver att truppen inte har flyttat denna omgång."

#: common/reqtext.c:1917
#, c-format
msgid "Requires that the unit is performing activity %s."
msgstr "Kräver att truppen utför aktiviteten %s."

#: common/reqtext.c:1921
#, c-format
msgid "Requires that the unit is not performing activity %s."
msgstr "Kräver att truppen inte utför aktiviteten %s."

#. TRANS: %s is numeric move points; it may have a
#. * fractional part ("1 1/3 MP").
#: common/reqtext.c:1951
#, c-format
msgid "Requires that the unit has at least %s MP left."
msgstr "Kräver att truppen har minst %s FP kvar."

#. TRANS: %s is numeric move points; it may have a
#. * fractional part ("1 1/3 MP").
#: common/reqtext.c:1957
#, c-format
msgid "Requires that the unit has less than %s MP left."
msgstr "Kräver att truppen har mindre än %s FP kvar."

#: common/reqtext.c:1987
#, c-format
msgid "Requires a unit with at least %d veteran level."
msgid_plural "Requires a unit with at least %d veteran levels."
msgstr[0] "Kräver en trupp med minst veterannivå %d."
msgstr[1] "Kräver en trupp med minst veterannivå %d."

#: common/reqtext.c:1993
#, c-format
msgid "Requires a unit with fewer than %d veteran level."
msgid_plural "Requires a unit with fewer than %d veteran levels."
msgstr[0] "Kräver en trupp med färre än %d veterannivå."
msgstr[1] "Kräver en trupp med färre än %d veterannivåer."

#: common/reqtext.c:2008
#, c-format
msgid "Requires a unit with at least %d hit point left."
msgid_plural "Requires a unit with at least %d hit points left."
msgstr[0] "Kräver en trupp med minst %d hälsopoäng kvar."
msgstr[1] "Kräver en trupp med minst %d hälsopoäng kvar."

#: common/reqtext.c:2014
#, c-format
msgid "Requires a unit with fewer than %d hit point left."
msgid_plural "Requires a unit with fewer than %d hit points left."
msgstr[0] "Kräver en trupp med färre än %d hälsopoäng kvar."
msgstr[1] "Kräver en trupp med färre än %d hälsopoäng kvar."

#. TRANS: "Applies only to Food."
#: common/reqtext.c:2030
#, c-format
msgid "?output:Applies only to %s."
msgstr "Gäller endast %s."

#. TRANS: "Does not apply to Food."
#: common/reqtext.c:2034
#, c-format
msgid "?output:Does not apply to %s."
msgstr "Gäller inte %s."

#. TRANS: "Applies only to Scientists."
#: common/reqtext.c:2046
#, c-format
msgid "?specialist:Applies only to %s."
msgstr "Gäller endast %s."

#. TRANS: "Does not apply to Scientists."
#: common/reqtext.c:2050
#, c-format
msgid "?specialist:Does not apply to %s."
msgstr "Gäller inte %s."

#: common/reqtext.c:2061
#, c-format
msgid "Requires a minimum city size of %d for this city or a trade partner."
msgid_plural "Requires a minimum city size of %d for this city or a trade partner."
msgstr[0] "Kräver en stadsstorlek på minst %d för denna stad eller en handelspartner."
msgstr[1] "Kräver en stadsstorlek på minst %d för denna stad eller en handelspartner."

#: common/reqtext.c:2069
#, c-format
msgid "Requires the city size to be less than %d for this city and all trade partners."
msgid_plural "Requires the city size to be less than %d for this city and all trade partners."
msgstr[0] "Kräver att stadsstorleken är mindre än %d för denna stad och alla handelspartner."
msgstr[1] "Kräver att stadsstorleken är mindre än %d för denna stad och alla handelspartner."

#: common/reqtext.c:2081
#, c-format
msgid "Requires a minimum city size of %d."
msgid_plural "Requires a minimum city size of %d."
msgstr[0] "Kräver en stadsstorlek på minst %d."
msgstr[1] "Kräver en stadsstorlek på minst %d."

#: common/reqtext.c:2087
#, c-format
msgid "Requires the city size to be less than %d."
msgid_plural "Requires the city size to be less than %d."
msgstr[0] "Kräver att stadsstorleken är mindre än %d."
msgstr[1] "Kräver att stadsstorleken är mindre än %d."

#: common/reqtext.c:2114
#, c-format
msgid "Requires a minimum culture of %d in the city."
msgid_plural "Requires a minimum culture of %d in the city."
msgstr[0] "Kräver minst %d kultur i staden."
msgstr[1] "Kräver minst %d kultur i staden."

#: common/reqtext.c:2120
#, c-format
msgid "Requires the culture in the city to be less than %d."
msgid_plural "Requires the culture in the city to be less than %d."
msgstr[0] "Kräver att kulturen i staden är mindre än %d."
msgstr[1] "Kräver att kulturen i staden är mindre än %d."

#: common/reqtext.c:2132
#, c-format
msgid "Requires a minimum culture of %d in this city or a trade partner."
msgid_plural "Requires a minimum culture of %d in this city or a trade partner."
msgstr[0] "Kräver minst %d kultur i denna stad eller hos en handelspartner."
msgstr[1] "Kräver minst %d kultur i denna stad eller hos en handelspartner."

#: common/reqtext.c:2140
#, c-format
msgid "Requires the culture in this city and all trade partners to be less than %d."
msgid_plural "Requires the culture in this city and all trade partners to be less than %d."
msgstr[0] "Kräver att kulturen i denna stad och hos alla handelspartner är mindre än %d."
msgstr[1] "Kräver att kulturen i denna stad och hos alla handelspartner är mindre än %d."

#: common/reqtext.c:2152
#, c-format
msgid "Requires your nation to have culture of at least %d."
msgid_plural "Requires your nation to have culture of at least %d."
msgstr[0] "Kräver att ditt folkslag har minst %d kultur."
msgstr[1] "Kräver att ditt folkslag har minst %d kultur."

#: common/reqtext.c:2160
#, c-format
msgid "Prevented if your nation has culture of %d or more."
msgid_plural "Prevented if your nation has culture of %d or more."
msgstr[0] "Förhindras om ditt folkslag har kultur på %d eller mer."
msgstr[1] "Förhindras om ditt folkslag har kultur på %d eller mer."

#: common/reqtext.c:2172
#, c-format
msgid "Requires someone on your team to have culture of at least %d."
msgid_plural "Requires someone on your team to have culture of at least %d."
msgstr[0] "Kräver att någon i ditt lag har minst %d kultur."
msgstr[1] "Kräver att någon i ditt lag har minst %d kultur."

#: common/reqtext.c:2180
#, c-format
msgid "Prevented if anyone on your team has culture of %d or more."
msgid_plural "Prevented if anyone on your team has culture of %d or more."
msgstr[0] "Förhindras om någon i ditt lag har %d kultur eller mer."
msgstr[1] "Förhindras om någon i ditt lag har %d kultur eller mer."

#: common/reqtext.c:2192
#, c-format
msgid "Requires someone in your current alliance to have culture of at least %d."
msgid_plural "Requires someone in your current alliance to have culture of at least %d."
msgstr[0] "Kräver att någon i ditt nuvarande förbund har minst %d kultur."
msgstr[1] "Kräver att någon i ditt nuvarande förbund har minst %d kultur."

#: common/reqtext.c:2200
#, c-format
msgid "Prevented if anyone in your current alliance has culture of %d or more."
