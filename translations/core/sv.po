#: ai/default/daicity.c:1000
#, c-format
#| msgid "%s is selling %s (obsolete) for %d."
msgid "%s is selling %s for %d."
msgid_plural "%s is selling %s for %d."
msgstr[0] "%s säljer %s för %d."
msgstr[1] "%s säljer %s för %d."

#: ai/default/daidiplomacy.c:371
#, c-format
msgid "*%s (AI)* In away mode AI can't sign such a treaty."
msgstr "*%s (datorstyrd)* Datorstyrd spelare i bortaläge kan inte anta ett sådant avtal."

#: ai/default/daidiplomacy.c:381
#, c-format
msgid "*%s (AI)* First break alliance with %s, %s."
msgstr "*%s (datorstyrd)* Bryt först förbundet med %s, %s."

#: ai/default/daidiplomacy.c:391
#, c-format
msgid "*%s (AI)* I would like to see you keep your distance from %s for some time, %s."
msgstr "*%s (datorstyrd)* Jag vill att du håller dig borta från %s ett tag först, %s."

#: ai/default/daidiplomacy.c:405
#, c-format
msgid "*%s (AI)* Let us first cease hostilities, %s."
msgstr "*%s (datorstyrd)* Låt oss först upphöra med fientligheter, %s."

#: ai/default/daidiplomacy.c:410
#, c-format
msgid "*%s (AI)* I wish to see you keep the current ceasefire for a bit longer first, %s."
msgstr "*%s (datorstyrd)* Jag vill se att du kan hålla vårt vapenstillestånd först, %s."

#: ai/default/daidiplomacy.c:433
#, c-format
msgid "*%s (AI)* I simply do not trust you with an alliance yet, %s."
msgstr "*%s (datorstyrd)* Jag litar ännu inte tillräckligt på dig för att ingå ett förbund, %s."

#: ai/default/daidiplomacy.c:527
#, c-format
msgid "*%s (AI)* I do not know the city you mention."
msgstr "*%s (datorstyrd)* Jag känner inte till staden du nämner."

#: ai/default/daidiplomacy.c:558
#, c-format
msgid "*%s (AI)* Sorry, sharing vision with you is not safe."
msgstr "*%s (datorstyrd)* Jag är rädd att det inte är säkert att dela anblick med dig."

#: ai/default/daidiplomacy.c:688
#, c-format
msgid "*%s (AI)* This deal was not very good for us, %s!"
msgstr "*%s (datorstyrd)* Det här är inte ett acceptabelt avtal, %s!"

#: ai/default/daidiplomacy.c:711
#, c-format
msgid "*%s (AI)* Welcome into our alliance %s!"
msgstr "*%s (datorstyrd)* Välkommen i vårt förbund %s!"

#: ai/default/daidiplomacy.c:715
#, c-format
msgid "*%s (AI)* Yes, may we forever stand united, %s."
msgstr "*%s (datorstyrd)* Ja, må vi stå enade för evigt, %s."

#: ai/default/daidiplomacy.c:722
#, c-format
msgid "*%s (AI)* Yes, peace in our time!"
msgstr "*%s (datorstyrd)* Ja, fred i vår tid!"

#: ai/default/daidiplomacy.c:727
#, c-format
msgid "*%s (AI)* Agreed. No more hostilities, %s."
msgstr "*%s (datorstyrd)* Avgjort. Inga fler fientligheter, %s."

#: ai/default/daidiplomacy.c:994
#, c-format
msgid "*%s (AI)* Greetings %s! May we suggest a ceasefire while we get to know each other better?"
msgstr "*%s (datorstyrd)* Var hälsad %s! Får vi lov att föreslå ett vapenstillestånd medan vi lär känna varandra bättre?"

#: ai/default/daidiplomacy.c:1002
#, c-format
msgid "*%s (AI)* I found you %s! Now make it worth my letting you live, or be crushed."
msgstr "*%s (datorstyrd)* Jag hittade dig, %s! Gör det nu värt besväret att låta dig leva, annars blir du krossad."

#: ai/default/daidiplomacy.c:1356
#, c-format
#| msgid "*%s (AI)* Space will never be yours. "
msgid "*%s (AI)* Space will never be yours."
msgstr "*%s (datorstyrd)* Rymden må aldrig bli din."

#: ai/default/daidiplomacy.c:1362
#, c-format
msgid "*%s (AI)* I have tolerated your vicious antics long enough! To war!"
msgstr "*%s (datorstyrd)* Jag har fått stå ut med dina nycker länge nog! Nu drar vi ut i krig!"

#: ai/default/daidiplomacy.c:1368
#, c-format
msgid "*%s (AI)* Peace in ... some other time."
msgstr "*%s (datorstyrd)* Fred i ... någon annan tid."

#: ai/default/daidiplomacy.c:1374
#, c-format
msgid "*%s (AI)* Finally I get around to you! Did you really think you could get away with your crimes?"
msgstr "*%s (datorstyrd)* Äntligen kan jag ta mig an dig! Trodde du verkligen att du skulle komma undan med dina förbrytelser?"

#: ai/default/daidiplomacy.c:1381
#, c-format
msgid "*%s (AI)* Your covert hostilities brought this war upon you!"
msgstr "*%s (datorstyrd)* Dina skumraskaffärer har kostat dig detta krig!"

#: ai/default/daidiplomacy.c:1389
#, c-format
msgid "*%s (AI)* Your aggression against %s was your last mistake!"
msgstr "*%s (datorstyrd)* Dina fientligheter mot %s var ditt sista mistag!"

#: ai/default/daidiplomacy.c:1496
#, c-format
msgid "*%s (AI)* We will be launching an all-out war against %s in %d turn to stop the spaceship launch."
msgid_plural "*%s (AI)* We will be launching an all-out war against %s in %d turns to stop the spaceship launch."
msgstr[0] "*%s (datorstyrd)* Jag kommer starta krig mot %s om %d omgång för att sätta stopp för dennes rymdskepp."
msgstr[1] "*%s (datorstyrd)* Jag kommer starta krig mot %s om %d omgångar för att sätta stopp för dennes rymdskepp."

#: ai/default/daidiplomacy.c:1507
#, c-format
msgid "*%s (AI)* Your aid in this matter will be expected. Long live our glorious alliance!"
msgstr "*%s (datorstyrd)* Jag ser fram emot din hjälp i detta ärende. Länge leve vårt storslagna förbund!"

#: ai/default/daidiplomacy.c:1514
#, c-format
#| msgid "*%s (AI)* %s has grossly violated his treaties with us for own gain.  We will answer in force in %d turn and expect you to honor your alliance with us and do likewise!"
#| msgid_plural "*%s (AI)* %s has grossly violated his treaties with us for own gain.  We will answer in force in %d turns and expect you to honor your alliance with us and do likewise!"
msgid "*%s (AI)* %s has grossly violated their treaties with us for own gain.  We will answer in force in %d turn and expect you to honor your alliance with us and do likewise!"
msgid_plural "*%s (AI)* %s has grossly violated their treaties with us for own gain.  We will answer in force in %d turns and expect you to honor your alliance with us and do likewise!"
msgstr[0] "*%s (datorstyrd)* %s har grovt brutit mot sina avtal med oss för egen vinning. Vi kommer att svara med kraft om %d omgång och förväntar oss att du hedrar ditt förbund med oss och gör detsamma!"
msgstr[1] "*%s (datorstyrd)* %s har grovt brutit mot sina avtal med oss för egen vinning. Vi kommer att svara med kraft om %d omgångar och förväntar oss att du hedrar ditt förbund med oss och gör detsamma!"

#: ai/default/daidiplomacy.c:1528
#, c-format
msgid "*%s (AI)* We intend to pillage and plunder the rich civilization of %s. We declare war in %d turn."
msgid_plural "*%s (AI)* We intend to pillage and plunder the rich civilization of %s. We declare war in %d turns."
msgstr[0] "*%s (datorstyrd)* Jag har för avsikt förklara krig mot %s om %d omgång för att plundra dem på deras rikedomar."
msgstr[1] "*%s (datorstyrd)* Jag har för avsikt förklara krig mot %s om %d omgångar för att plundra dem på deras rikedomar."

#: ai/default/daidiplomacy.c:1537
#, c-format
msgid "*%s (AI)* If you want a piece of the loot, feel free to join in the action!"
msgstr "*%s (datorstyrd)* Önskar du ha del i krigsbytet så varsågod att ta del i striden!"

#: ai/default/daidiplomacy.c:1543
#, c-format
msgid "*%s (AI)* We have had it with %s. Let us tear this pathetic civilization apart. We declare war in %d turn."
msgid_plural "*%s (AI)* We have had it with %s. Let us tear this pathetic civilization apart. We declare war in %d turns."
msgstr[0] "*%s (datorstyrd)* Jag har fått nog av %s. Tiden har kommit att slita dem i stycken. Jag förklarar krig om %d omgång."
msgstr[1] "*%s (datorstyrd)* Jag har fått nog av %s. Tiden har kommit att slita dem i stycken. Jag förklarar krig om %d omgångar."

#: ai/default/daidiplomacy.c:1554
#, c-format
msgid "*%s (AI)* As our glorious allies, we expect your help in this war."
msgstr "*%s (datorstyrd)* Jag förutsätter att ni, min betrodde bundsförvant, medverkar i detta krig."

#: ai/default/daidiplomacy.c:1561
#, c-format
msgid "*%s (AI)* We will honor our alliance and declare war on %s in %d turn.  Hold on - we are coming!"
msgid_plural "*%s (AI)* We will honor our alliance and declare war on %s in %d turns.  Hold on - we are coming!"
msgstr[0] "*%s (datorstyrd)* Jag har för avsikt att hedra vårt förbund och förklara krig mot %s om %d omgång. Håll ut - vi är på väg!"
msgstr[1] "*%s (datorstyrd)* Jag har för avsikt att hedra vårt förbund och förklara krig mot %s om %d omgångar. Håll ut - vi är på väg!"

#: ai/default/daidiplomacy.c:1571
#, c-format
msgid "*%s (AI)* We will honor our alliance with %s and declare war on %s in %d turns.  We expect you to do likewise."
msgid_plural "*%s (AI)* We will honor our alliance with %s and declare war on %s in %d turns.  We expect you to do likewise."
msgstr[0] "*%s (datorstyrd)* Jag har för avsikt att hedra mitt förbund med %s och förklara krig mot %s om %d omgång. Vi förutsätter att ni gör detsamma."
msgstr[1] "*%s (datorstyrd)* Jag har för avsikt att hedra mitt förbund med %s och förklara krig mot %s om %d omgångar. Vi förutsätter att ni gör detsamma."

#: ai/default/daidiplomacy.c:1652
#, c-format
msgid "*%s (AI)* Your attempt to conquer space for yourself alone betrays your true intentions, and I will have no more of our alliance!"
msgstr "*%s (datorstyrd)* Ditt försök att ensam erövra rymden avslöjar dina verkliga avsikter, och jag avslutar vårt förbund!"

#: ai/default/daidiplomacy.c:1668
#, c-format
msgid "*%s (AI)* Your attempt to unilaterally dominate outer space is highly offensive."
msgstr "*%s (datorstyrd)* Ditt försök att ensam härska i yttre rymden är mycket anstötligt."

#: ai/default/daidiplomacy.c:1672
#, c-format
msgid "*%s (AI)* If you do not stop constructing your spaceship, I may be forced to take action!"
msgstr "*%s (datorstyrd)* Om du inte avbryter bygget av ditt rymdskepp kan jag tvingas ingripa!"

#: ai/default/daidiplomacy.c:1795
#, c-format
msgid "*%s (AI)* Sorry, sharing vision with you is no longer safe."
msgstr "*%s (datorstyrd)* Jag är rädd att det inte längre är säkert att dela anblick med dig."

#: ai/default/daidiplomacy.c:1866
#, c-format
msgid "*%s (AI)* Greetings our most trustworthy ally. We call upon you to destroy our enemy, %s."
msgstr "*%s (datorstyrd)* Var hälsad vår mest pålitliga bundsförvant, vi uppmanar er att utplåna vår fiende, %s."

#: ai/default/daidiplomacy.c:1874
#, c-format
msgid "*%s (AI)* Greetings ally, I see you have not yet made war with our enemy, %s. Why do I need to remind you of your promises?"
msgstr "*%s (datorstyrd)* Vad hälsad bundsförvant, jag ser att du ännu inte har förklarat krig mot vår fiende, %s. Varför behöver jag påminna dig om dina löften?"

#: ai/default/daidiplomacy.c:1884
#, c-format
msgid "*%s (AI)* Dishonored one, we made a pact of alliance, and yet you remain at peace with our mortal enemy, %s! This is unacceptable; our alliance is no more!"
msgstr "*%s (datorstyrd)* Din usling, vi slöt ett förbund, men du har fortfarande fred med vår dödsfiende, %s! Detta är inte godtagbard, vårt förbund har upphört!"

#: ai/default/daidiplomacy.c:1918
#, c-format
msgid "*%s (AI)* Greetings friend, may we suggest making a common cause and join in an alliance?"
msgstr "*%s (datorstyrd)* Var hälsad vän, får jag föreslå att vi ingår ett förbund med varandra?"

#: ai/default/daidiplomacy.c:1935
#, c-format
msgid "*%s (AI)* Greetings neighbor, may we suggest more peaceful relations?"
msgstr "*%s (datorstyrd)* Var hälsad granne, vad sägs om ett fredsfördrag?"

#: ai/default/daidiplomacy.c:1952
#, c-format
msgid "*%s (AI)* We grow weary of this constant bloodshed. May we suggest a cessation of hostilities?"
msgstr "*%s (datorstyrd)* All denna blodspillan leder ingen vart. Är det inte dags att gräva ner stridsyxan?"

#: ai/default/daidiplomacy.c:2241
#, c-format
msgid "*%s (AI)* We have been savagely attacked by %s, and we need your help! Honor our glorious alliance and your name will never be forgotten!"
msgstr "*%s (datorstyrd)* Jag har blivit brutalt överfallen av %s och är i behov av hjälp! Hedra vårt förbund och er hjälpsamhet kommer inte gå förbi obemärkt!"

#: ai/difficulty.c:252
msgid "Toggles 'away' mode for your nation. In away mode, the AI will govern your nation but make only minimal changes."
msgstr "Växlar \"borta\"-läge för din nation. I bortaläge styr AI:n din nation men gör endast minimala ändringar."

#: ai/difficulty.c:258
#, c-format
msgid "With no arguments, sets all AI players to skill level '%s', and sets the default level for any new AI players to '%s'. With an argument, sets the skill level for the specified player only."
msgstr "Utan argument sätter detta kommando alla datorstyrda spelares till skicklighetsnivån ”%s” och sätter standardskicklighetsnivå för varje ny datorstyrd spelare till ”%s”. Med ett argument sätter kommandot skicklighetsnivån för endast den spelaren."

#: ai/difficulty.c:276
msgid "Has erratic decision-making."
msgstr "Fattar oberäkneliga beslut."

#: ai/difficulty.c:283
#, c-format
msgid "Research takes %d%% as long as usual."
msgstr "Forskning tar %d%% av normal tid."

#: ai/difficulty.c:287
msgid "Has reduced appetite for expansion."
msgstr "Har minskad vilja att expandera."

#: ai/difficulty.c:294
msgid ""
"\n"
"This skill level has the same features as 'Novice', but may suffer additional ruleset-defined penalties."
msgstr ""
"\n"
"Den här svårighetsgraden har samma egenskaper som ”Nybörjare”, men kan drabbas av ytterligare avdrag som definieras av regelverket."

#: ai/difficulty.c:300
msgid ""
"\n"
"This skill level has the same features as 'Hard', but may enjoy additional ruleset-defined bonuses."
msgstr ""
"\n"
"Den här svårighetsgraden har samma egenskaper som ”Svår”, men kan få ytterligare bonusar som definieras av regelverket."

#: ai/difficulty.c:309
msgid ""
"\n"
"This skill level's features include the following. (Some rulesets may define extra level-specific behavior.)"
msgstr ""
"\n"
"Den här svårighetsgradens egenskaper omfattar följande. (Vissa regelverk kan definiera ytterligare beteenden som är specifika för nivån.)"

#: ai/handicaps.c:86
msgid "Doesn't build offensive diplomatic units."
msgstr "Bygger inte offensiva diplomatiska trupper."

#: ai/handicaps.c:90
msgid "Gets reduced bonuses from huts."
msgstr "Får reducerade bonusar från hyddor."

#: ai/handicaps.c:92
msgid "Prefers defensive buildings and avoids close diplomatic relations."
msgstr "Föredrar defensiva byggnader och undviker nära diplomatiska förbindelser."

#: ai/handicaps.c:95
msgid "THIS IS ONLY FOR TESTING OF NEW AI FEATURES! For ordinary servers, this level is no different to 'Hard'."
msgstr "DETTA ÄR ENDAST AVSETT FÖR TESTNING AV NYA AI-FUNKTIONER! På vanliga servrar skiljer sig denna nivå inte från ”Svår”."

#: ai/handicaps.c:99
msgid "Has no restrictions on tax rates."
msgstr "Har inga begränsningar för skattesatser."

#: ai/handicaps.c:102
msgid "Can target units and cities in unseen or unexplored territory."
msgstr "Kan välja trupper och städer i osedda eller oupptäckta områden som mål."

#: ai/handicaps.c:105
msgid "Knows the location of huts in unexplored territory."
msgstr "Känner till var hyddor finns i oupptäckta områden."

#: ai/handicaps.c:108
msgid "Can see through fog of war."
msgstr "Kan se genom krigets dimma."

#: ai/handicaps.c:110
msgid "Doesn't build air units."
msgstr "Bygger inte stridsflyg."

#: ai/handicaps.c:113
msgid "Has complete map knowledge, including unexplored territory."
msgstr "Har fullständig kännedom om kartan, även oupptäckta områden."

#: ai/handicaps.c:115
msgid "Naive at diplomacy."
msgstr "Naiv i diplomati."

#: ai/handicaps.c:118
msgid "Can skip anarchy during revolution."
msgstr "Kan hoppa över anarki under revolution."

#: ai/handicaps.c:120
msgid "Limits growth to match human players."
msgstr "Begränsar tillväxten för att matcha mänskliga spelare."

#: ai/handicaps.c:122
msgid "Believes its cities are always under threat."
msgstr "Tror att dess städer alltid är hotade."

#: ai/handicaps.c:124
msgid "Always offers cease-fire on first contact."
msgstr "Erbjuder alltid vapenstillestånd vid första kontakten."

#: ai/handicaps.c:126
msgid "Doesn't bribe worker or city founder units."
msgstr "Mutar inte arbetare eller stadsgrundare."

#: ai/handicaps.c:129
msgid "Can change city production type without penalty."
msgstr "Kan byta typ av stadsproduktion utan avdrag."

#: ai/handicaps.c:131
msgid "Limits the distance to search for threatening enemy units."
msgstr "Begränsar avståndet vid sökning efter hotande fiendetrupper."

#: ai/tex/texai.c:594
msgid "This Freeciv compilation has no full threads implementation, tex ai cannot be used."
msgstr "Den här Freeciv-kompileringen saknar fullständig trådhantering; tex-AI:n kan inte användas."

#: client/agents/cma_core.c:403 server/cityturn.c:423
#, c-format
msgid "The citizen governor can't fulfill the requirements for %s. Passing back control."
msgstr "Stadsförvaltaren kan inte utföra sitt uppdrag i %s och lämnar sin post."

#: client/agents/cma_core.c:412 client/agents/cma_core.c:432
#, c-format
msgid "The citizen governor has gotten confused dealing with %s.  You may want to have a look."
msgstr "Stadsförvaltaren är osäker på att han skött sitt uppdrag i %s och ber att vi tar oss en titt."

#: client/agents/cma_fec.c:226 client/gui-gtk-3.22/cityrep.c:771 client/gui-gtk-3.22/cityrep.c:797 client/gui-gtk-4.0/cityrep.c:782 client/gui-gtk-4.0/cityrep.c:821 client/gui-gtk-5.0/cityrep.c:952 client/gui-gtk-5.0/cityrep.c:991
#| msgid "?cma:Governor"
msgid "?cma:none"
msgstr "ingen"

